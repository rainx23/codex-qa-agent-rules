  "$comment": "Generated from scripts/qa_contracts.py; do not edit manually.",
  "x-rule-version": "2.18.0",
  "title": "Risk Coverage Matrix",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "matrix_id",
    "analysis_ids",
    "risk_items",
    "coverage_summary"
