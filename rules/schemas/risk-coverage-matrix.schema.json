      "type": "string",
      "minLength": 1
    },
    "model_id": {
      "type": "string",
      "minLength": 1
    },
    "report_mode": {
      "enum": [
        "requirement",
        "diff",
        "combined"
      ]
    },
    "workflow_stage": {
      "enum": [
        "pre_review",
        "confirmation_only",
        "formal_generation",
        "completed"
      ]
    },
    "rule_version": {
      "const": "2.18.0"
    },
    "generated_at": {
      "type": "string",
      "minLength": 1,
      "pattern": "^\\d{4}-\\d{2}-\\d{2} \\d{2}:\\d{2}:\\d{2}$"
    },
    "generated_timezone": {
      "enum": [
        "Asia/Shanghai",
        "UTC"
