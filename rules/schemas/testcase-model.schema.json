{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$comment": "Generated from scripts/qa_contracts.py; do not edit manually.",
  "x-rule-version": "2.12.0",
  "title": "Testcase Model",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "root_title",
    "cases"
  ],
  "properties": {
    "schema_version": {
      "const": "2.0.0"
    },
    "model_id": {
      "type": "string",
      "minLength": 1
    },
    "root_title": {
      "type": "string",
      "minLength": 1
    },
    "cases": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "tc_id",
          "dimension",
          "common_entry",
          "module_level_1",
          "module_level_2",
          "test_point",
          "steps",
          "expected_results",
          "risk_ids",
          "requirement_ids",
          "change_ids",
          "historical_defect_ids",
          "test_priority",
          "evidence_state",
          "regression_scope",
          "deduplication_key"
        ],
        "properties": {
          "tc_id": {
            "type": "string",
            "minLength": 1,
            "pattern": "^TC\\d{3}$"
          },
          "dimension": {
            "enum": [
              "功能测试",
              "数据测试",
              "异常测试",
              "权限测试",
              "导出测试",
              "兼容性测试",
              "回归测试",
              "SQL验证"
            ]
          },
          "secondary_dimensions": {
            "type": "array",
            "items": {
              "enum": [
                "功能测试",
                "数据测试",
                "异常测试",
                "权限测试",
                "导出测试",
                "兼容性测试",
                "回归测试",
                "SQL验证"
              ]
            },
            "uniqueItems": true
          },
          "common_entry": {
            "type": [
              "string",
              "null"
            ]
          },
          "module_level_1": {
            "type": [
              "string",
              "null"
            ]
          },
          "module_level_2": {
            "type": [
              "string",
              "null"
            ]
          },
          "test_point": {
            "type": "string",
            "minLength": 1
          },
          "steps": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 0,
            "uniqueItems": true
          },
          "expected_results": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 0,
            "uniqueItems": true
          },
          "actions": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "step_id",
                "action",
                "expected_results"
              ],
              "properties": {
                "step_id": {
                  "type": "string",
                  "minLength": 1,
                  "pattern": "^STEP\\d{3}$"
                },
                "action": {
                  "type": "string",
                  "minLength": 1
                },
                "expected_results": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  },
                  "minItems": 1,
                  "uniqueItems": true
                }
              }
            }
          },
          "risk_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 1,
            "uniqueItems": true
          },
          "requirement_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 0,
            "uniqueItems": true
          },
          "change_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 0,
            "uniqueItems": true
          },
          "historical_defect_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 0,
            "uniqueItems": true
          },
          "entry_branches": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "branch_id",
                "entry_name",
                "steps",
                "expected_results"
              ],
              "properties": {
                "branch_id": {
                  "type": "string",
                  "minLength": 1
                },
                "entry_name": {
                  "type": "string",
                  "minLength": 1
                },
                "steps": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  },
                  "minItems": 1,
                  "uniqueItems": true
                },
                "expected_results": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  },
                  "minItems": 1,
                  "uniqueItems": true
                }
              }
            },
            "minItems": 2,
            "uniqueItems": true
          },
          "preconditions": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 0,
            "uniqueItems": true
          },
          "test_data_refs": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 0,
            "uniqueItems": true
          },
          "environment_refs": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 0,
            "uniqueItems": true
          },
          "role_refs": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 0,
            "uniqueItems": true
          },
          "cleanup_steps": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 0,
            "uniqueItems": true
          },
          "oracle_sources": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 0,
            "uniqueItems": true
          },
          "automation_candidate": {
            "enum": [
              "yes",
              "no",
              "unknown"
            ]
          },
          "automation_reason": {
            "type": "string",
            "minLength": 1
          },
          "test_priority": {
            "enum": [
              "P0",
              "P1",
              "P2"
            ]
          },
          "evidence_state": {
            "enum": [
              "已确认",
              "疑似",
              "待确认"
            ]
          },
          "regression_scope": {
            "enum": [
              "核心回归",
              "关联回归",
              "冒烟回归"
            ]
          },
          "deduplication_key": {
            "type": "string",
            "minLength": 1
          },
          "core_deduplication_factors": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "business_object",
              "trigger_condition",
              "core_action",
              "core_assertion",
              "risk_semantics"
            ],
            "properties": {
              "business_object": {
                "type": "string",
                "minLength": 1
              },
              "trigger_condition": {
                "type": "string",
                "minLength": 1
              },
              "core_action": {
                "type": "string",
                "minLength": 1
              },
              "core_assertion": {
                "type": "string",
                "minLength": 1
              },
              "risk_semantics": {
                "type": "string",
                "minLength": 1
              },
              "data_source": {
                "type": "string",
                "minLength": 1
              },
              "permission_rule": {
                "type": "string",
                "minLength": 1
              },
              "calculation_basis": {
                "type": "string",
                "minLength": 1
              },
              "exception_handling": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "core_deduplication_key": {
            "type": "string",
            "minLength": 1,
            "pattern": "^sha256:[0-9a-fA-F]{64}$"
          },
          "split_reason": {
            "enum": [
              "data_source",
              "permission_rule",
              "calculation_basis",
              "operation",
              "oracle",
              "exception_handling",
              "risk_diagnostic"
            ]
          },
          "split_reason_detail": {
            "type": "string",
            "minLength": 1
          },
          "condition_coverage": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "combination_id",
                "coverage_type",
                "dimension_values",
                "expected_match_state",
                "observable_result"
              ],
              "properties": {
                "combination_id": {
                  "type": "string",
                  "minLength": 1
                },
                "coverage_type": {
                  "enum": [
                    "behavior",
                    "configuration"
                  ]
                },
                "dimension_values": {
                  "type": "object"
                },
                "expected_match_state": {
                  "type": "string",
                  "minLength": 1
                },
                "observable_result": {
                  "type": "string",
                  "minLength": 1
                },
                "branch_id": {
                  "type": "string",
                  "minLength": 1
                },
                "step_index": {
                  "type": "integer",
                  "minimum": 1
                },
                "expected_index": {
                  "type": "integer",
                  "minimum": 1
                },
                "scope_path": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  },
                  "minItems": 1,
                  "uniqueItems": true
                }
              }
            },
            "uniqueItems": true
          },
          "shared_entry_scope_id": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "minItems": 1
    },
    "branch_count": {
      "type": "integer",
      "minimum": 0
    },
    "execution_instance_count": {
      "type": "integer",
      "minimum": 0
    },
    "execution_instances": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "execution_instance_id",
          "tc_id",
          "branch_id",
          "execution_status",
          "executor",
          "executed_at",
          "defect_ids",
          "rerun_of",
          "execution_evidence"
        ],
        "properties": {
          "execution_instance_id": {
            "type": "string",
            "minLength": 1
          },
          "tc_id": {
            "type": "string",
            "minLength": 1,
            "pattern": "^TC\\d{3}$"
          },
          "branch_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "execution_status": {
            "enum": [
              "not_run",
              "passed",
              "failed",
              "blocked",
              "skipped"
            ]
          },
          "executor": {
            "type": [
              "string",
              "null"
            ]
          },
          "executed_at": {
            "type": [
              "string",
              "null"
            ]
          },
          "defect_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 0,
            "uniqueItems": true
          },
          "rerun_of": {
            "type": [
              "string",
              "null"
            ]
          },
          "execution_evidence": {
            "type": [
              "object",
              "string",
              "null"
            ]
          },
          "failure_description": {
            "type": [
              "string",
              "null"
            ]
          },
          "confirmation_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 0,
            "uniqueItems": true
          },
          "decision_evidence": {
            "type": [
              "object",
              "string",
              "null"
            ]
          }
        }
      }
    },
    "shared_entry_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scope_id",
        "scope_title",
        "applies_to_tc_ids",
        "groups"
      ],
      "properties": {
        "scope_id": {
          "type": "string",
          "minLength": 1
        },
        "scope_title": {
          "const": "适用入口（以下全部TC均需逐项执行）"
        },
        "applies_to_tc_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^TC\\d{3}$"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "groups": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "group_name",
              "subgroups"
            ],
            "properties": {
              "group_name": {
                "type": "string",
                "minLength": 1
              },
              "subgroups": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "subgroup_name",
                    "entries"
                  ],
                  "properties": {
                    "subgroup_name": {
                      "type": "string",
                      "minLength": 1
                    },
                    "entries": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "additionalProperties": false,
                        "required": [
                          "entry_name"
                        ],
                        "properties": {
                          "entry_name": {
                            "type": "string",
                            "minLength": 1
                          }
                        }
                      },
                      "minItems": 1
                    }
                  }
                },
                "minItems": 1
              }
            }
          },
          "minItems": 1
        }
      }
    }
  }
}
