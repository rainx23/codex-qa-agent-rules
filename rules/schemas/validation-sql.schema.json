{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$comment": "Generated from scripts/qa_contracts.py; do not edit manually.",
  "x-rule-version": "2.8.0",
  "title": "Validation SQL Artifact Model",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "sql_items"
  ],
  "properties": {
    "schema_version": {
      "const": "2.0.0"
    },
    "sql_items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "sql_id",
          "purpose",
          "requirement_ids",
          "risk_ids",
          "tc_ids",
          "dialect",
          "tables",
          "fields",
          "parameters",
          "metric_ids",
          "expected_assertion",
          "execution_status",
          "sql_path",
          "evidence_sources",
          "identifier_evidence"
        ],
        "properties": {
          "sql_id": {
            "type": "string",
            "minLength": 1,
            "pattern": "^SQLV\\d{3}$"
          },
          "purpose": {
            "type": "string",
            "minLength": 1
          },
          "requirement_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 0,
            "uniqueItems": true
          },
          "risk_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 1,
            "uniqueItems": true
          },
          "tc_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1,
              "pattern": "^TC\\d{3}$"
            },
            "minItems": 1,
            "uniqueItems": true
          },
          "dialect": {
            "type": "string",
            "minLength": 1
          },
          "tables": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 1,
            "uniqueItems": true
          },
          "fields": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 0,
            "uniqueItems": true
          },
          "parameters": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 0,
            "uniqueItems": true
          },
          "metric_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 0,
            "uniqueItems": true
          },
          "expected_assertion": {
            "type": "string",
            "minLength": 1
          },
          "execution_status": {
            "enum": [
              "planned",
              "generated",
              "reviewed",
              "executed",
              "passed",
              "failed",
              "blocked"
            ]
          },
          "sql_path": {
            "type": "string",
            "minLength": 1
          },
          "evidence_sources": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 1,
            "uniqueItems": true
          },
          "identifier_evidence": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "identifier",
                "identifier_type",
                "qualified_identifier",
                "scope_table",
                "usage_type",
                "source_reference_type",
                "source_reference_id",
                "evidence_references",
                "evidence_state"
              ],
              "properties": {
                "identifier": {
                  "type": "string",
                  "minLength": 1
                },
                "identifier_type": {
                  "enum": [
                    "table",
                    "column",
                    "function",
                    "enum_value",
                    "parameter",
                    "join_key",
                    "filter_value"
                  ]
                },
                "qualified_identifier": {
                  "type": "string",
                  "minLength": 1
                },
                "scope_table": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "usage_type": {
                  "type": "string",
                  "minLength": 1
                },
                "source_reference": {
                  "type": "string",
                  "minLength": 1
                },
                "source_reference_type": {
                  "enum": [
                    "knowledge_table",
                    "knowledge_table_field",
                    "complete_ddl",
                    "fact",
                    "change",
                    "formal_document",
                    "code_context",
                    "builtin_sql",
                    "user_confirmation"
                  ]
                },
                "source_reference_id": {
                  "type": "string",
                  "minLength": 1
                },
                "evidence_references": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": [
                      "source_type",
                      "storage_type",
                      "source_path",
                      "snapshot_path",
                      "source_record_id",
                      "line_start",
                      "line_end",
                      "commit_sha",
                      "content_hash",
                      "excerpt",
                      "captured_at",
                      "captured_timezone",
                      "evidence_status"
                    ],
                    "properties": {
                      "source_type": {
                        "enum": [
                          "user_confirmation",
                          "requirement",
                          "zentao_section_3",
                          "openspec",
                          "markdown",
                          "screenshot",
                          "diff",
                          "code_context",
                          "acceptance_criteria",
                          "formal_change_record",
                          "api_document",
                          "sql_definition",
                          "complete_ddl",
                          "knowledge_table",
                          "historical_defect",
                          "pasted_text",
                          "chat_snapshot"
                        ]
                      },
                      "storage_type": {
                        "enum": [
                          "file",
                          "snapshot"
                        ]
                      },
                      "source_path": {
                        "type": [
                          "string",
                          "null"
                        ]
                      },
                      "snapshot_path": {
                        "type": [
                          "string",
                          "null"
                        ]
                      },
                      "source_record_id": {
                        "type": [
                          "string",
                          "null"
                        ]
                      },
                      "line_start": {
                        "type": [
                          "integer",
                          "null"
                        ],
                        "minimum": 1
                      },
                      "line_end": {
                        "type": [
                          "integer",
                          "null"
                        ],
                        "minimum": 1
                      },
                      "commit_sha": {
                        "type": [
                          "string",
                          "null"
                        ],
                        "pattern": "^[0-9a-fA-F]{7,40}$"
                      },
                      "content_hash": {
                        "type": [
                          "string",
                          "null"
                        ],
                        "pattern": "^sha256:[0-9a-fA-F]{64}$"
                      },
                      "excerpt": {
                        "type": "string",
                        "minLength": 1
                      },
                      "captured_at": {
                        "type": "string",
                        "minLength": 1,
                        "pattern": "^\\d{4}-\\d{2}-\\d{2} \\d{2}:\\d{2}:\\d{2}$"
                      },
                      "captured_timezone": {
                        "enum": [
                          "Asia/Shanghai",
                          "UTC"
                        ]
                      },
                      "evidence_status": {
                        "enum": [
                          "current",
                          "stale",
                          "reconfirm_required"
                        ]
                      },
                      "stale_reason": {
                        "type": [
                          "string",
                          "null"
                        ]
                      },
                      "working_tree_evidence": {
                        "type": "boolean"
                      }
                    }
                  },
                  "minItems": 1
                },
                "evidence_state": {
                  "const": "confirmed"
                }
              }
            },
            "minItems": 1
          },
          "execution_evidence": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      },
      "minItems": 1
    }
  }
}
