{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "QA Artifact Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_id", "source_type", "source_id", "source_hash", "rule_version",
    "generated_at", "report_path", "xmind_md_path", "xmind_path",
    "case_count", "p0_count", "pending_count", "validation_status",
    "relation", "supersedes"
  ],
  "properties": {
    "artifact_id": {"type": "string", "minLength": 1},
    "source_type": {"type": "string", "minLength": 1},
    "source_id": {"type": "string", "minLength": 1},
    "source_hash": {"type": "string", "pattern": "^sha256:[0-9a-fA-F]{64}$"},
    "requirement_id": {"type": "string"},
    "commit_range": {"type": "string"},
    "rule_version": {"type": "string", "minLength": 1},
    "generated_at": {"type": "string", "minLength": 1},
    "report_path": {"type": "string"},
    "xmind_md_path": {"type": "string"},
    "xmind_path": {"type": "string"},
    "case_count": {"type": "integer", "minimum": 0},
    "p0_count": {"type": "integer", "minimum": 0},
    "pending_count": {"type": "integer", "minimum": 0},
    "validation_status": {"enum": ["passed", "failed", "pending"]},
    "relation": {"enum": ["新增", "补充", "替代", "废弃"]},
    "supersedes": {"type": ["string", "null"]},
    "failure_reason": {"type": "string"}
  },
  "anyOf": [
    {"required": ["requirement_id"]},
    {"required": ["commit_range"]}
  ],
  "allOf": [
    {
      "if": {"properties": {"relation": {"enum": ["替代", "废弃"]}}},
      "then": {"properties": {"supersedes": {"type": "string", "minLength": 1}}}
    },
    {
      "if": {"properties": {"validation_status": {"const": "failed"}}},
      "then": {"required": ["failure_reason"]}
    }
  ]
}

